# ─────────────────────────────────────────────────────────────────────────────
#  RevLock (RevPasswordManager P2) — .gitignore
#  Spring Boot 3 · Java 17 · Maven · Oracle SQL · Thymeleaf
# ─────────────────────────────────────────────────────────────────────────────


# ──────────────────────────────────────────────────────
# MAVEN BUILD OUTPUT
# ──────────────────────────────────────────────────────
target/
!**/src/main/**/target/
!**/src/test/**/target/
*.class
*.jar
*.war
*.ear
*.zip
*.tar.gz
*.rar
release.properties
dependency-reduced-pom.xml
buildNumber.properties
.mvn/timing.properties
.mvn/wrapper/maven-wrapper.jar


# ──────────────────────────────────────────────────────
# SENSITIVE CONFIGURATION — NEVER COMMIT THESE
# ──────────────────────────────────────────────────────
# Contains DB passwords, email passwords, encryption secret
src/main/resources/application.properties
src/main/resources/application.yml
src/main/resources/application-prod.properties
src/main/resources/application-prod.yml

# Allow the template/example config to be committed
!src/main/resources/application.properties.example
!src/main/resources/application-example.properties


